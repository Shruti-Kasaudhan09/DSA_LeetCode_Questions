#QUESTION 9
class Solution {
    public boolean isPalindrome(int x) {

        int org=x;
        int rev=0;

        if(x<0){
            return false;
        }
        while(x!=0){
            int d =x%10;
            rev=rev*10+d;
            x=x/10;
        }
      return org==rev;
    }
    }
